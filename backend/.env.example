# Backend runtime configuration

# Core service
DATABASE_URL=sqlite:///./threat_copilot.db
FRONTEND_CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
APP_LOG_LEVEL=INFO
APP_LOG_FILE_PATH=./runtime_logs/app/app.log

# Pipeline event storage (local)
PIPELINE_LOG_STORAGE_PATH=./runtime_logs/pipeline

# Optional external DB API log sink
# Set your base URL, for example: https://my-db-api.company.internal
PIPELINE_LOG_DB_API_URL=
# Path appended to the base URL above.
PIPELINE_LOG_DB_API_PATH=/pipeline/logs
PIPELINE_LOG_FORWARD_ENABLED=true

# Description LLM provider
# provider: openai|ollama (configured inside service)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1:8b

# Playbook agent LLM planner
PLAYBOOK_AGENT_ENABLE_LLM=1
PLAYBOOK_LLM_PROVIDER=ollama
PLAYBOOK_LLM_MODEL=llama3.1:8b
